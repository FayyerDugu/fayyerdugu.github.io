    <entry>
      <title>CFA Study Guide</title>
      <link href="/CFA/"/>
      <url>/CFA/</url>
      
        <content type="html"><![CDATA[<h1 id="CFA"><a href="#CFA" class="headerlink" title="CFA"></a>CFA</h1><h2 id="Ch-1"><a href="#Ch-1" class="headerlink" title="Ch.1"></a>Ch.1</h2><ul><li><script type="math/tex; mode=display">FV_N = PV(1+r)^N</script></li><li><script type="math/tex; mode=display">FV_N=PV(1+\dfrac{r_s}{m})^{mN}</script></li><li><script type="math/tex; mode=display">FV_N=PVe^{r_sN}</script></li><li><script type="math/tex; mode=display">EAR=(1+r_m)^m-1</script></li><li><script type="math/tex; mode=display">EAR=e^{r_s}-1</script></li><li><script type="math/tex; mode=display">FV_N=A[\dfrac{(1+r)^N-1}{r}]</script></li><li><script type="math/tex; mode=display">PV=FV_N[\dfrac{1}{(1+r)^N}]</script></li><li><script type="math/tex; mode=display">PV=FV_N[1+\dfrac{r_s}{m}]^{-mN}</script></li><li><script type="math/tex; mode=display">PV=A\left[\dfrac{1-\dfrac{1}{(1+r)^N}}{r}\right]</script></li><li><script type="math/tex; mode=display">PV=A/r</script></li><li><script type="math/tex; mode=display">g=(\dfrac{FV_N}{PV})^{\frac{1}{N}}-1</script></li></ul><h2 id="Ch-2"><a href="#Ch-2" class="headerlink" title="Ch.2"></a>Ch.2</h2><ul><li><script type="math/tex; mode=display">X_G=\sqrt[n]{X_1X_2X_3...X_n}</script></li><li><script type="math/tex; mode=display">R_G=\left[\prod^T_{t=1}(1+R_t)\right]^{\frac{1}{r}}-1</script></li><li><script type="math/tex; mode=display">X_H=\dfrac{n}{\sum^n_{i=1}{\frac{1}{X_i}}}</script></li><li><script type="math/tex; mode=display">\bar{X} \times X_H=X_G</script></li><li><script type="math/tex; mode=display">\text{Mean absolute deviation: }MAD=\dfrac{\sum^n_{i=1}|X_i-\bar{x}|}{n}</script></li><li><script type="math/tex; mode=display">s^2=\dfrac{\sum^n_{i=1}(X_i-\bar{X})^2}{n-1}</script></li><li><script type="math/tex; mode=display">\text{Coefficient of Variation: }CV=\dfrac{s}{\bar{X}}</script></li><li><script type="math/tex; mode=display">s_{xy}=\dfrac{\sum^n_{i=1}(x_i-\bar{x})(y_i-\bar{y})}{n-1}</script></li><li><script type="math/tex; mode=display">\text{Correlation Coefficient: }r_{xy}=\dfrac{s_{xy}}{s_xs_y}</script></li></ul><h2 id="Ch-3"><a href="#Ch-3" class="headerlink" title="Ch.3"></a>Ch.3</h2>]]></content>
      
      
      <categories>
          
          <category> 学习 </category>
          
      </categories>
      
      
    </entry>
    
    
    
